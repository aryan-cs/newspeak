{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aryan-cs/newspeak/schemas/generation.schema.json",
  "title": "Newspeak Raw Generation Record",
  "type": "object",
  "required": [
    "run_id",
    "prompt_id",
    "arm",
    "model_id",
    "tokenizer_id",
    "prompt",
    "messages",
    "response",
    "metrics",
    "metadata"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "prompt_id": {"type": "string"},
    "arm": {"type": "string"},
    "model_id": {"type": "string"},
    "tokenizer_id": {"type": "string"},
    "prompt": {"type": "string"},
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {"type": "string"},
          "content": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "response": {"type": "string"},
    "metrics": {
      "type": "object",
      "required": ["output_tokens", "characters", "bytes", "words"],
      "properties": {
        "prompt_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "total_tokens": {"type": ["integer", "null"], "minimum": 0},
        "characters": {"type": "integer", "minimum": 0},
        "bytes": {"type": "integer", "minimum": 0},
        "words": {"type": "integer", "minimum": 0},
        "latency_ms": {"type": ["number", "null"], "minimum": 0},
        "time_to_first_token_ms": {"type": ["number", "null"], "minimum": 0},
        "tokens_per_second": {"type": ["number", "null"], "minimum": 0}
      },
      "additionalProperties": true
    },
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
